{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/kuosuko/registry/main/schema/manifest.schema.json",
  "title": "Suko CMS declarative extension manifest v1",
  "description": "Mirrors the zod schema in cms/src/ext/dx/manifest.ts (manifestSchema, Core v2 architecture spec section 3.2). Validated at install time AND at interpret time. Generated by cms/scripts/gen-manifest-schema.mts -- do not hand-edit; re-run the script after changing manifest.ts. Two zod superRefine cross-checks (installPrompts[].key must reference settings[].key with matching secret; dashboardCards[].contentType must reference a declared contentTypes[].name) cannot be expressed in JSON Schema and are noted on the relevant properties instead.",
  "type": "object",
  "required": [
    "kind",
    "id",
    "name",
    "version",
    "coreApi"
  ],
  "additionalProperties": false,
  "properties": {
    "kind": {
      "type": "string",
      "const": "declarative",
      "description": "Only 'declarative' manifests are validated by this schema. 'code' extensions (metadata stub with an install command) are a different, unvalidated shape."
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]{1,30}$",
      "description": "Extension id. Full content type keys become '<id>.<typeName>'."
    },
    "name": {
      "anyOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "object",
          "properties": {
            "en": {
              "type": "string"
            },
            "zh-Hant": {
              "type": "string"
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Exact semver x.y.z of this manifest."
    },
    "coreApi": {
      "type": "string",
      "pattern": "^(\\^|~|>=)?\\d+\\.\\d+\\.\\d+$",
      "description": "Semver range checked against CORE_API_VERSION. Supports ^x.y.z, ~x.y.z, exact, >=x.y.z."
    },
    "description": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "object",
          "properties": {
            "en": {
              "type": "string"
            },
            "zh-Hant": {
              "type": "string"
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "icon": {
      "type": "string",
      "description": "Declarative extension icon hint (lucide token). Used for admin sidebar / menus."
    },
    "iconUrl": {
      "type": "string",
      "description": "PNG icon relative path in registry (e.g. 'icon.png' under extensions/<id>/)."
    },
    "banner": {
      "type": "string",
      "description": "Top banner image relative path (e.g. 'banner.png')."
    },
    "screenshots": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Screenshots list (relative paths)."
    },
    "deployment": {
      "type": "string",
      "enum": [
        "instant",
        "progressive",
        "code-only"
      ],
      "description": "instant = usable immediately; progressive = usable after install but full experience needs a rebuild; code-only = must rebuild."
    },
    "installPrompts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/installPrompt"
      },
      "description": "Fields to prompt the installing user for (marketplace shows a form). Each entry's `key` must reference an existing settings[].key with a matching `secret` flag (zod superRefine cross-check; not expressible in JSON Schema)."
    },
    "customApiRoutes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/customApiRoute"
      },
      "description": "1.9.0: custom read-only API endpoints other apps may call. Acts as an allow-list of which content types are exposed publicly. v1 is read-only: method must be 'GET'."
    },
    "capabilities": {
      "maxItems": 16,
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "description": "Platform capabilities this extension needs (install-time feature-gating, core-v2 roadmap #17). Intentionally not an enum here -- unknown names may come from a newer core version; compared against src/ext/features.ts at install time instead."
    },
    "requires": {
      "maxItems": 16,
      "type": "array",
      "items": {
        "$ref": "#/$defs/requiresEntry"
      },
      "description": "Service/provider requirements (deliberately separate axis from capabilities): capabilities is core's static feature table, requires is 'which provider must be present' (providers.ts capability registry, e.g. email:send, cron:tick). A non-optional entry that is absent blocks install; an optional one just surfaces a suggestion in the UI."
    },
    "author": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "url": {
          "type": "string",
          "pattern": "^https:\\/\\/"
        },
        "email": {
          "type": "string",
          "pattern": "^(?!\\.)(?!.*\\.\\.)([A-Za-z0-9_'+\\-\\.]*)[A-Za-z0-9_+-]@([A-Za-z0-9][A-Za-z0-9\\-]*\\.)+[A-Za-z]{2,}$"
        }
      },
      "required": [
        "name"
      ],
      "description": "zod does not call .strict() on this object, so additional properties are permitted here (unlike most other manifest objects)."
    },
    "homepage": {
      "type": "string",
      "pattern": "^https:\\/\\/",
      "description": "homepage must be https"
    },
    "repository": {
      "type": "string",
      "pattern": "^https:\\/\\/",
      "description": "repository must be https"
    },
    "license": {
      "type": "string",
      "minLength": 1,
      "description": "SPDX id (e.g. 'MIT'); display only, not SPDX-validated."
    },
    "tags": {
      "maxItems": 8,
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "description": "Discoverability tags: search matching + detail page chips."
    },
    "category": {
      "type": "string",
      "enum": [
        "content",
        "media",
        "commerce",
        "integration",
        "utility",
        "theme"
      ]
    },
    "support": {
      "type": "object",
      "properties": {
        "url": {
          "type": "string",
          "pattern": "^https:\\/\\/"
        },
        "email": {
          "type": "string",
          "pattern": "^(?!\\.)(?!.*\\.\\.)([A-Za-z0-9_'+\\-\\.]*)[A-Za-z0-9_+-]@([A-Za-z0-9][A-Za-z0-9\\-]*\\.)+[A-Za-z]{2,}$"
        }
      },
      "description": "zod does not call .strict() on this object, so additional properties are permitted here."
    },
    "theme": {
      "$ref": "#/$defs/theme"
    },
    "stylesheet": {
      "type": "string",
      "const": "style.css",
      "description": "1.8.0: optional co-located stylesheet. v1 fixes the filename as the literal 'style.css' (no arbitrary paths, to prevent path traversal / fetching arbitrary assets). Installed content is validated by validateStylesheet before being stored."
    },
    "contentTypes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/contentType"
      }
    },
    "settings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/settingField"
      }
    },
    "adminPages": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/adminPage"
      }
    },
    "publicRoutes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/publicRoute"
      }
    },
    "og": {
      "type": "object",
      "properties": {
        "image": {
          "type": "object",
          "properties": {
            "template": {
              "type": "string",
              "minLength": 1,
              "description": "Core og-template name, corresponds to src/components/og/<slug>.tsx."
            },
            "brand": {
              "type": "string"
            }
          },
          "required": [
            "template"
          ]
        }
      },
      "description": "Optional Open Graph preview config: which core og-template public routes' preview images use. Neither this object nor og.image calls .strict() in zod, so additional properties are permitted at both levels."
    },
    "migrations": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/migrationStatement"
      },
      "description": "Optional DDL. Each entry is a single idempotent statement that must start with CREATE (TABLE|UNIQUE INDEX|INDEX) ... IF NOT EXISTS. No ';' statement-splitting or inline ';'. DROP/INSERT/UPDATE/ALTER are deferred to v1.1 (needs transaction semantics)."
    },
    "on": {
      "type": "object",
      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {
        "type": "array",
        "items": {
          "$ref": "#/$defs/hookAction"
        }
      },
      "description": "Hook name -> array of declarative action bindings. v1 supports webhook actions only."
    },
    "dashboardCards": {
      "maxItems": 4,
      "type": "array",
      "items": {
        "$ref": "#/$defs/dashboardCard"
      },
      "description": "roadmap #16: extension-contributed dashboard cards (stat/recent). Each card's `contentType` must reference a declared contentTypes[].name (zod superRefine cross-check; not expressible in JSON Schema). Adding this field is a CORE_API minor bump (1.5.0 -> 1.6.0): a manifest using it must declare coreApi \"^1.6.0\" or higher, since older core rejects unknown-strict-object fields entirely."
    },
    "schedule": {
      "maxItems": 8,
      "type": "array",
      "items": {
        "$ref": "#/$defs/scheduleItem"
      },
      "description": "B (docs/spec-declarative-notify-schedule.md, CORE_API 1.11.0): declarative scheduled actions (<=8), interpreted into Extension.jobs and executed by the ext-jobs core job (docs/spec-extension-jobs.md) -- no new engine. Adding this field is a CORE_API minor bump (1.10.0 -> 1.11.0): a manifest using it must declare coreApi \"^1.11.0\" or higher."
    },
    "loginProvider": {
      "type": "object",
      "properties": {
        "issuer": {
          "type": "string",
          "pattern": "^https:\\/\\/"
        },
        "scopes": {
          "maxItems": 8,
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "button": {
          "type": "object",
          "properties": {
            "label": {
              "type": "string",
              "minLength": 1,
              "maxLength": 40
            },
            "svg": {
              "type": "string",
              "maxLength": 4000,
              "description": "Optional brand icon. Validated by src/ext/dx/svg-guard.ts (allowlist of svg/g/path/circle/rect/ellipse/line/polyline/polygon/defs/linearGradient/radialGradient/stop/clipPath/title; rejects on*= handlers, <script>, javascript:, href/xlink:href, <foreignObject>, <image>, <use>, <style>, <animate*>, external URLs). Rejection fails manifest validation (fail-loud). Not expressible as a JSON Schema constraint beyond maxLength."
            },
            "background": {
              "$ref": "#/$defs/themeColor"
            },
            "foreground": {
              "$ref": "#/$defs/themeColor"
            }
          },
          "required": [
            "label"
          ],
          "additionalProperties": false
        }
      },
      "required": [
        "issuer",
        "button"
      ],
      "additionalProperties": false,
      "description": "spec-login-providers.md §4 (CORE_API 1.16.0): declarative third-party OIDC login. `issuer` is the OIDC issuer (discovery is fetched by the engine); `scopes` defaults to [openid, profile, email]. Client id/secret are NOT declared here -- they use the existing settings[] convention (clientId text, clientSecret secret:true), read by the engine at ext.<extId>.clientId / .clientSecret. button.svg is validated by an allowlist svg-guard at parse time (zod refine, dropped by z.toJSONSchema; the maxLength 4000 pattern is enforced but the tag/attribute allowlist is not expressible in JSON Schema). Adding this field is a CORE_API minor bump (1.14.0 -> 1.16.0, 1.15.0 reserved for extension i18n): a manifest using it must declare coreApi \"^1.16.0\"."
    }
  },
  "$defs": {
    "fieldKey": {
      "type": "string",
      "pattern": "^[a-zA-Z][a-zA-Z0-9_]*$"
    },
    "typeName": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]{0,30}$"
    },
    "relationTo": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]{1,30}\\.[a-z][a-z0-9-]{0,30}$",
      "description": "relation/relations only: target content type key '<extId>.<typeName>'."
    },
    "routePattern": {
      "type": "string",
      "pattern": "^(\\/[a-z0-9-]+|\\/:[a-zA-Z][a-zA-Z0-9]*)+$",
      "description": "Plain segment string with ':param' placeholders only. No regex metacharacters; compiled by the O(n) segment matcher."
    },
    "listLayout": {
      "type": "string",
      "enum": [
        "table",
        "grid",
        "stacked"
      ],
      "description": "core-v2 §3.5 listing layout. 'table' (default) = one entry per row; 'grid' = responsive card grid; 'stacked' = vendored StackedList sweep-in animation. Absent = table (back-compat). 'table'/'grid' require coreApi ^1.1.0; 'stacked' requires coreApi ^1.7.0."
    },
    "leafField": {
      "type": "object",
      "properties": {
        "key": {
          "$ref": "#/$defs/fieldKey"
        },
        "type": {
          "type": "string",
          "enum": [
            "text",
            "richtext",
            "number",
            "boolean",
            "date",
            "media",
            "select",
            "slug",
            "json",
            "relation",
            "relations"
          ]
        },
        "label": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "object",
              "properties": {
                "en": {
                  "type": "string"
                },
                "zh-Hant": {
                  "type": "string"
                }
              },
              "additionalProperties": false
            }
          ]
        },
        "required": {
          "type": "boolean"
        },
        "options": {
          "minItems": 1,
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "select only."
        },
        "to": {
          "$ref": "#/$defs/relationTo"
        },
        "multiline": {
          "type": "boolean",
          "description": "text only: upgrades the input to a fullscreen textarea overlay (TextFullscreenEditor)."
        }
      },
      "required": [
        "key",
        "type"
      ],
      "additionalProperties": false,
      "description": "A leaf (single-value) field. Usable as a top-level field AND as a nested subfield of group/repeater/blocks. Structural types are NOT leaf fields (a structural field may not nest another structural field -- one level of nesting only, v1).",
      "allOf": [
        {
          "if": {
            "properties": {
              "type": {
                "const": "select"
              }
            },
            "required": [
              "type"
            ]
          },
          "then": {
            "required": [
              "key",
              "type",
              "options"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "enum": [
                  "relation",
                  "relations"
                ]
              }
            },
            "required": [
              "type"
            ]
          },
          "then": {
            "required": [
              "key",
              "type",
              "to"
            ]
          },
          "else": {
            "not": {
              "required": [
                "to"
              ]
            }
          }
        },
        {
          "if": {
            "not": {
              "properties": {
                "type": {
                  "const": "text"
                }
              },
              "required": [
                "type"
              ]
            }
          },
          "then": {
            "not": {
              "required": [
                "multiline"
              ]
            }
          }
        }
      ]
    },
    "leafFields": {
      "minItems": 1,
      "type": "array",
      "items": {
        "$ref": "#/$defs/leafField"
      }
    },
    "groupField": {
      "type": "object",
      "properties": {
        "key": {
          "$ref": "#/$defs/fieldKey"
        },
        "type": {
          "type": "string",
          "const": "group"
        },
        "label": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "object",
              "properties": {
                "en": {
                  "type": "string"
                },
                "zh-Hant": {
                  "type": "string"
                }
              },
              "additionalProperties": false
            }
          ]
        },
        "required": {
          "type": "boolean"
        },
        "fields": {
          "$ref": "#/$defs/leafFields"
        }
      },
      "required": [
        "key",
        "type",
        "fields"
      ],
      "additionalProperties": false,
      "description": "Tier 2 v1.2: nested fieldset. Stored value: { ...subfield values }. Its `fields` are leaf fields only (one level of nesting)."
    },
    "repeaterField": {
      "type": "object",
      "properties": {
        "key": {
          "$ref": "#/$defs/fieldKey"
        },
        "type": {
          "type": "string",
          "const": "repeater"
        },
        "label": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "object",
              "properties": {
                "en": {
                  "type": "string"
                },
                "zh-Hant": {
                  "type": "string"
                }
              },
              "additionalProperties": false
            }
          ]
        },
        "required": {
          "type": "boolean"
        },
        "fields": {
          "$ref": "#/$defs/leafFields"
        },
        "max": {
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 9007199254740991
        }
      },
      "required": [
        "key",
        "type",
        "fields"
      ],
      "additionalProperties": false,
      "description": "Tier 2 v1.2: sortable ordered list of groups. Stored value: [{ ... }, ...]. Its `fields` are leaf fields only (one level of nesting). Optional `max` caps the row count."
    },
    "blockDef": {
      "type": "object",
      "properties": {
        "name": {
          "$ref": "#/$defs/typeName"
        },
        "label": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "object",
              "properties": {
                "en": {
                  "type": "string"
                },
                "zh-Hant": {
                  "type": "string"
                }
              },
              "additionalProperties": false
            }
          ]
        },
        "fields": {
          "$ref": "#/$defs/leafFields"
        }
      },
      "required": [
        "name",
        "fields"
      ],
      "additionalProperties": false,
      "description": "One named block shape declared by a blocks field. Its `fields` are leaf fields only."
    },
    "blocksField": {
      "type": "object",
      "properties": {
        "key": {
          "$ref": "#/$defs/fieldKey"
        },
        "type": {
          "type": "string",
          "const": "blocks"
        },
        "label": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "object",
              "properties": {
                "en": {
                  "type": "string"
                },
                "zh-Hant": {
                  "type": "string"
                }
              },
              "additionalProperties": false
            }
          ]
        },
        "required": {
          "type": "boolean"
        },
        "blocks": {
          "minItems": 1,
          "type": "array",
          "items": {
            "$ref": "#/$defs/blockDef"
          }
        },
        "max": {
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 9007199254740991
        }
      },
      "required": [
        "key",
        "type",
        "blocks"
      ],
      "additionalProperties": false,
      "description": "Tier 2 v1.2: block-type chooser + repeater, the declarable page-builder primitive. Stored value: [{ block: '<name>', ...fields }, ...]. Declares named block shapes; each block's `fields` are leaf fields only. Optional `max` caps the instance count."
    },
    "field": {
      "description": "A top-level content-type field: any leaf field, or a Tier 2 structural field (group/repeater/blocks). Structural fields contain leaf fields only (one level of nesting, v1).",
      "oneOf": [
        {
          "$ref": "#/$defs/leafField"
        },
        {
          "$ref": "#/$defs/groupField"
        },
        {
          "$ref": "#/$defs/repeaterField"
        },
        {
          "$ref": "#/$defs/blocksField"
        }
      ]
    },
    "formLayoutColumn": {
      "type": "object",
      "properties": {
        "fields": {
          "minItems": 1,
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "fullWidth": {
          "type": "boolean"
        }
      },
      "required": [
        "fields"
      ],
      "additionalProperties": false
    },
    "formLayout": {
      "type": "object",
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "auto2col",
            "single",
            "manual"
          ]
        },
        "groups": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/formLayoutColumn"
          },
          "description": "Only valid when kind = 'manual'. Each group's fields render in the listed order; a group's fields all share the same row alignment."
        },
        "wide": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "description": "Default wide keys in manual mode -- these fields always take the full row width."
        }
      },
      "required": [
        "kind"
      ],
      "additionalProperties": false,
      "description": "Progressive form layout. 'auto2col' = declarative baseline (full-row tall fields, paired short fields). 'single' = single column stack. 'manual' = author-defined groups; keys are field names that must exist on this content type. manual layout requires groups (zod refine: at least one group when kind='manual').",
      "if": {
        "properties": {
          "kind": {
            "const": "manual"
          }
        },
        "required": [
          "kind"
        ]
      },
      "then": {
        "required": [
          "kind",
          "groups"
        ],
        "properties": {
          "groups": {
            "type": "array",
            "minItems": 1
          }
        }
      }
    },
    "contentType": {
      "type": "object",
      "properties": {
        "name": {
          "$ref": "#/$defs/typeName",
          "description": "Local type name. Full type key becomes '<extId>.<name>'."
        },
        "label": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "object",
              "properties": {
                "en": {
                  "type": "string"
                },
                "zh-Hant": {
                  "type": "string"
                }
              },
              "additionalProperties": false
            }
          ]
        },
        "slugField": {
          "type": "string",
          "description": "Key of the field used as the auto-slug source."
        },
        "fields": {
          "minItems": 1,
          "type": "array",
          "items": {
            "$ref": "#/$defs/field"
          }
        },
        "public": {
          "type": "boolean",
          "description": "Alpha: declares this type public (anonymous POST creates a new entry). dispatch(/api/ext/...) skips requireAuth for POST when the matched type is public:true; origin checks / other guards still apply."
        },
        "notifyOnCreate": {
          "type": "boolean",
          "description": "A (docs/spec-declarative-notify-schedule.md, CORE_API 1.11.0): best-effort notification email sent after a successful public create. Recipient is the core.notifyEmail setting (empty = disabled). Only takes effect when `public` is true."
        },
        "layout": {
          "$ref": "#/$defs/formLayout"
        }
      },
      "required": [
        "name",
        "fields"
      ],
      "additionalProperties": false
    },
    "settingOption": {
      "type": "object",
      "properties": {
        "value": {
          "type": "string"
        },
        "label": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "object",
              "properties": {
                "en": {
                  "type": "string"
                },
                "zh-Hant": {
                  "type": "string"
                }
              },
              "additionalProperties": false
            }
          ]
        }
      },
      "required": [
        "value",
        "label"
      ],
      "additionalProperties": false
    },
    "settingField": {
      "type": "object",
      "properties": {
        "key": {
          "$ref": "#/$defs/fieldKey"
        },
        "label": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "object",
              "properties": {
                "en": {
                  "type": "string"
                },
                "zh-Hant": {
                  "type": "string"
                }
              },
              "additionalProperties": false
            }
          ]
        },
        "description": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "object",
              "properties": {
                "en": {
                  "type": "string"
                },
                "zh-Hant": {
                  "type": "string"
                }
              },
              "additionalProperties": false
            }
          ]
        },
        "default": {},
        "secret": {
          "type": "boolean"
        },
        "type": {
          "type": "string",
          "enum": [
            "text",
            "textarea",
            "number",
            "boolean",
            "select"
          ]
        },
        "options": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/settingOption"
          }
        }
      },
      "required": [
        "key",
        "label",
        "default",
        "type"
      ],
      "additionalProperties": false,
      "description": "Same shape as the code extension SettingField.",
      "if": {
        "properties": {
          "type": {
            "const": "select"
          }
        },
        "required": [
          "type"
        ]
      },
      "then": {
        "required": [
          "key",
          "label",
          "default",
          "type",
          "options"
        ],
        "properties": {
          "options": {
            "type": "array",
            "minItems": 1
          }
        }
      }
    },
    "adminPage": {
      "type": "object",
      "properties": {
        "slug": {
          "type": "string",
          "description": "'' = extension main admin page."
        },
        "title": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "object",
              "properties": {
                "en": {
                  "type": "string"
                },
                "zh-Hant": {
                  "type": "string"
                }
              },
              "additionalProperties": false
            }
          ]
        },
        "view": {
          "type": "string",
          "const": "collection"
        },
        "contentType": {
          "type": "string",
          "description": "Local content type name (matches a contentTypes[].name)."
        },
        "layout": {
          "$ref": "#/$defs/listLayout"
        }
      },
      "required": [
        "slug",
        "title",
        "view",
        "contentType"
      ],
      "additionalProperties": false
    },
    "formSuccess": {
      "type": "object",
      "properties": {
        "message": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "object",
              "properties": {
                "en": {
                  "type": "string"
                },
                "zh-Hant": {
                  "type": "string"
                }
              },
              "additionalProperties": false
            }
          ]
        }
      },
      "additionalProperties": false
    },
    "publicRoute": {
      "type": "object",
      "properties": {
        "pattern": {
          "$ref": "#/$defs/routePattern"
        },
        "view": {
          "type": "string",
          "enum": [
            "list",
            "detail",
            "form"
          ]
        },
        "contentType": {
          "type": "string",
          "description": "Local content type name (matches a contentTypes[].name)."
        },
        "layout": {
          "allOf": [
            {
              "$ref": "#/$defs/listLayout"
            }
          ],
          "description": "list view only. Absent = table (back-compat)."
        },
        "success": {
          "allOf": [
            {
              "$ref": "#/$defs/formSuccess"
            }
          ],
          "description": "form view only: submission success feedback."
        },
        "stepped": {
          "type": "boolean",
          "description": "1.7.0: form view only. Splits the form into a vendored Stepper multi-step flow (<=3 fields per step, last step submits) when the content type has >=4 publicly-renderable fields. Only valid when view is 'form'."
        }
      },
      "required": [
        "pattern",
        "view",
        "contentType"
      ],
      "additionalProperties": false,
      "description": "Alpha: 'form' = anonymous public form submission (uses contentType + public:true).",
      "allOf": [
        {
          "if": {
            "not": {
              "properties": {
                "view": {
                  "const": "list"
                }
              },
              "required": [
                "view"
              ]
            }
          },
          "then": {
            "not": {
              "required": [
                "layout"
              ]
            }
          }
        },
        {
          "if": {
            "not": {
              "properties": {
                "view": {
                  "const": "form"
                }
              },
              "required": [
                "view"
              ]
            }
          },
          "then": {
            "not": {
              "required": [
                "success"
              ]
            }
          }
        },
        {
          "if": {
            "not": {
              "properties": {
                "view": {
                  "const": "form"
                }
              },
              "required": [
                "view"
              ]
            }
          },
          "then": {
            "not": {
              "required": [
                "stepped"
              ]
            }
          }
        }
      ]
    },
    "hookAction": {
      "type": "object",
      "properties": {
        "action": {
          "type": "string",
          "const": "webhook"
        },
        "url": {
          "type": "string",
          "pattern": "^https:\\/\\/",
          "description": "https only; outbound webhook target."
        },
        "secretSetting": {
          "type": "string",
          "description": "Key of a settings entry (secret:true) used to HMAC-SHA256 sign the payload."
        }
      },
      "required": [
        "action",
        "url"
      ],
      "additionalProperties": false
    },
    "installPrompt": {
      "type": "object",
      "properties": {
        "key": {
          "type": "string",
          "minLength": 1,
          "description": "Must reference an existing settings[].key (zod superRefine cross-check)."
        },
        "label": {
          "anyOf": [
            {
              "type": "string",
              "minLength": 1
            },
            {
              "type": "object",
              "properties": {
                "en": {
                  "type": "string"
                },
                "zh-Hant": {
                  "type": "string"
                }
              },
              "additionalProperties": false
            }
          ]
        },
        "type": {
          "type": "string",
          "enum": [
            "text",
            "textarea",
            "number",
            "boolean"
          ]
        },
        "required": {
          "type": "boolean"
        },
        "secret": {
          "type": "boolean",
          "description": "Must match the referenced settings[].secret flag (zod superRefine cross-check)."
        },
        "description": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "object",
              "properties": {
                "en": {
                  "type": "string"
                },
                "zh-Hant": {
                  "type": "string"
                }
              },
              "additionalProperties": false
            }
          ]
        }
      },
      "required": [
        "key",
        "label",
        "type"
      ],
      "description": "zod does not call .strict() on this object, so additional properties are permitted here."
    },
    "customApiRoute": {
      "type": "object",
      "properties": {
        "method": {
          "type": "string",
          "const": "GET",
          "description": "read-only v1: only GET is accepted. Older core versions accepted POST/PUT/DELETE; consumers using this field must declare coreApi ^1.9.0."
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "contentType": {
          "type": "string",
          "minLength": 1,
          "description": "Points at a content type declared by this same extension (local name). Listing it here marks that type as publicly exposed."
        },
        "responseShape": {
          "type": "object",
          "propertyNames": {
            "type": "string"
          },
          "additionalProperties": {},
          "description": "Documentation-only; not enforced at runtime."
        }
      },
      "required": [
        "method",
        "path"
      ],
      "additionalProperties": false
    },
    "requiresEntry": {
      "type": "object",
      "properties": {
        "capability": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*(:[a-z][a-z0-9-]*)?$",
          "description": "Provider capability name, matching providers.ts convention: 'name' or 'name:verb' (lowercase/digits/hyphens)."
        },
        "optional": {
          "type": "boolean",
          "description": "true = install may proceed without this provider present (UI shows a suggestion). Absent/false = missing provider blocks install."
        },
        "reason": {
          "anyOf": [
            {
              "type": "string",
              "maxLength": 200
            },
            {
              "type": "object",
              "properties": {
                "en": {
                  "type": "string"
                },
                "zh-Hant": {
                  "type": "string"
                }
              },
              "additionalProperties": false
            }
          ],
          "description": "User-facing explanation shown in the Browse UI's capability chips tooltip."
        }
      },
      "required": [
        "capability"
      ],
      "additionalProperties": false
    },
    "themeColor": {
      "type": "string",
      "pattern": "^(#[0-9a-fA-F]{3,8}|(oklch|rgb|hsl)\\([0-9a-zA-Z .,%/-]*\\))$",
      "description": "Hex or oklch()/rgb()/hsl(...) color. Must not contain ; { } < > \" ' (defense-in-depth against inline-style injection, on top of the character-class regex)."
    },
    "themeRadius": {
      "type": "string",
      "pattern": "^\\d+(\\.\\d+)?(px|rem)$",
      "description": "<number>px or <number>rem. Same injection-safety note as themeColor applies (character set already excludes the dangerous characters)."
    },
    "theme": {
      "type": "object",
      "properties": {
        "accent": {
          "$ref": "#/$defs/themeColor"
        },
        "background": {
          "$ref": "#/$defs/themeColor"
        },
        "muted": {
          "$ref": "#/$defs/themeColor"
        },
        "radius": {
          "$ref": "#/$defs/themeRadius"
        }
      },
      "additionalProperties": false,
      "description": "1.8.0: optional design tokens rendered into public pages as inline CSS custom properties (--ext-accent / --ext-bg / --ext-muted / --ext-radius). Admin ignores this. All fields optional."
    },
    "migrationStatement": {
      "type": "string",
      "minLength": 1,
      "pattern": "CREATE\\s+(TABLE|UNIQUE\\s+INDEX|INDEX)\\s+IF\\s+NOT\\s+EXISTS",
      "not": {
        "pattern": ";"
      },
      "description": "Single idempotent DDL statement. Must contain 'CREATE (TABLE|UNIQUE INDEX|INDEX) ... IF NOT EXISTS' (case-insensitive in zod; JSON Schema regex here is applied case-sensitively per draft2020 defaults, author in uppercase) and must not contain ';' anywhere (no multi-statement strings)."
    },
    "dashboardCard": {
      "type": "object",
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "stat",
            "recent"
          ]
        },
        "contentType": {
          "type": "string",
          "minLength": 1,
          "description": "Must reference a declared contentTypes[].name (zod superRefine cross-check; not expressible in JSON Schema)."
        },
        "title": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "object",
              "properties": {
                "en": {
                  "type": "string"
                },
                "zh-Hant": {
                  "type": "string"
                }
              },
              "additionalProperties": false
            }
          ],
          "description": "Absent -> falls back to the referenced contentType's label/name."
        },
        "status": {
          "type": "string",
          "enum": [
            "draft",
            "published"
          ],
          "description": "stat cards only: count only entries with this status."
        },
        "limit": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10,
          "description": "recent cards only: number of entries returned, default 5."
        }
      },
      "required": [
        "kind",
        "contentType"
      ],
      "additionalProperties": false,
      "description": "roadmap #16: one extension-contributed dashboard card. kind='stat' shows the entry count for a content type (optionally filtered by status); kind='recent' shows the most recently updated entries (limit 1..10, default 5). `status` is stat-only, `limit` is recent-only (zod refine).",
      "allOf": [
        {
          "if": {
            "not": {
              "properties": {
                "kind": {
                  "const": "stat"
                }
              },
              "required": [
                "kind"
              ]
            }
          },
          "then": {
            "not": {
              "required": [
                "status"
              ]
            }
          }
        },
        {
          "if": {
            "not": {
              "properties": {
                "kind": {
                  "const": "recent"
                }
              },
              "required": [
                "kind"
              ]
            }
          },
          "then": {
            "not": {
              "required": [
                "limit"
              ]
            }
          }
        }
      ]
    },
    "scheduleAction": {
      "type": "object",
      "properties": {
        "op": {
          "type": "string",
          "const": "deleteOlderThan"
        },
        "contentType": {
          "type": "string",
          "minLength": 1
        },
        "days": {
          "type": "integer",
          "minimum": 1,
          "maximum": 9007199254740991
        }
      },
      "required": [
        "op",
        "contentType",
        "days"
      ],
      "additionalProperties": false,
      "description": "v1 has a single op: deleteOlderThan. `contentType` names a contentTypes[].name declared by this same manifest (not cross-checked by zod; interpret skips schedule items pointing at an unknown type)."
    },
    "scheduleItem": {
      "type": "object",
      "properties": {
        "id": {
          "$ref": "#/$defs/typeName"
        },
        "every": {
          "type": "integer",
          "minimum": 1,
          "maximum": 9007199254740991
        },
        "action": {
          "$ref": "#/$defs/scheduleAction"
        }
      },
      "required": [
        "id",
        "every",
        "action"
      ],
      "additionalProperties": false,
      "description": "One declarative scheduled action, interpreted into an Extension.jobs entry and executed by the ext-jobs core job (docs/spec-extension-jobs.md). `id` must be unique across schedule[] (zod array refine; not expressible in JSON Schema)."
    }
  }
}
