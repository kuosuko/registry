{
  "kind": "declarative",
  "id": "contact",
  "name": {
    "en": "Contact",
    "zh-Hant": "聯絡"
  },
  "version": "1.3.3",
  "coreApi": "^1.17.0",
  "description": {
    "en": "Have questions? Leave a message and we'll get back to you as soon as possible.",
    "zh-Hant": "有任何問題歡迎留言,我們會盡快回覆。"
  },
  "icon": "mail",
  "contentTypes": [
    {
      "name": "submission",
      "label": {
        "en": "Contact submission",
        "zh-Hant": "聯絡我們"
      },
      "slugField": "email",
      "public": true,
      "fields": [
        {
          "key": "name",
          "type": "text",
          "label": {
            "en": "Name",
            "zh-Hant": "姓名"
          },
          "required": true
        },
        {
          "key": "email",
          "type": "text",
          "label": "Email",
          "required": true
        },
        {
          "key": "message",
          "type": "text",
          "label": {
            "en": "Message",
            "zh-Hant": "訊息"
          },
          "required": true
        }
      ],
      "notifyOnCreate": true
    }
  ],
  "adminPages": [
    {
      "slug": "",
      "title": {
        "en": "Contact submissions",
        "zh-Hant": "聯絡我們"
      },
      "view": "collection",
      "contentType": "submission",
      "layout": "table"
    }
  ],
  "publicRoutes": [
    {
      "pattern": "/contact",
      "view": "form",
      "contentType": "submission",
      "success": {
        "message": {
          "en": "Thanks for reaching out! We'll get back to you soon.",
          "zh-Hant": "收到你的訊息了,我們會盡快回覆,謝謝!"
        }
      }
    }
  ],
  "settings": [
    {
      "key": "webhookSecret",
      "label": {
        "en": "Webhook signature secret",
        "zh-Hant": "Webhook 簽章密鑰"
      },
      "description": {
        "en": "HMAC-SHA256 signature secret for the content:created webhook (optional; leave empty to not sign).",
        "zh-Hant": "content:created webhook 的 HMAC-SHA256 簽章密鑰(可選;留空則不簽署)。"
      },
      "type": "text",
      "default": "",
      "secret": true
    }
  ],
  "on": {
    "content:created": [
      {
        "action": "webhook",
        "url": "https://hooks.example.com/REPLACE_WITH_YOUR_ENDPOINT",
        "secretSetting": "webhookSecret"
      }
    ]
  },
  "author": {
    "name": "kuosuko",
    "url": "https://suko.tw"
  },
  "repository": "https://github.com/kuosuko/registry",
  "license": "MIT",
  "category": "content",
  "tags": [
    "contact",
    "form",
    "email",
    "webhook"
  ],
  "deployment": "instant",
  "capabilities": [
    "contents",
    "public-create",
    "webhooks",
    "settings",
    "admin-pages",
    "public-routes"
  ],
  "installPrompts": [
    {
      "key": "webhookSecret",
      "label": "Webhook 簽章密鑰",
      "type": "text",
      "secret": true,
      "description": "content:created webhook 的 HMAC-SHA256 簽章密鑰(可選;留空則不簽署,之後可在 Settings 補)。"
    }
  ],
  "iconUrl": "icon.png",
  "schedule": [
    {
      "id": "purge-old-submissions",
      "every": 1440,
      "action": {
        "op": "deleteOlderThan",
        "contentType": "submission",
        "days": 180
      }
    }
  ]
}
