{
  "kind": "declarative",
  "id": "line-login",
  "name": {
    "en": "LINE Login",
    "zh-Hant": "LINE 登入"
  },
  "version": "1.0.1",
  "coreApi": "^1.17.0",
  "description": {
    "en": "Sign in with LINE (OIDC). The email scope requires LINE review; without it users get a placeholder address and can add a real one later.",
    "zh-Hant": "使用 LINE 登入 (OIDC)。Email 範圍需要 LINE 審核;未經審核時使用者會取得預留位置地址,之後可新增真實地址。"
  },
  "author": { "name": "kuosuko" },
  "license": "MIT",
  "category": "integration",
  "tags": ["auth", "login", "oidc", "line"],
  "deployment": "instant",
  "repository": "https://github.com/kuosuko/registry",
  "loginProvider": {
    "issuer": "https://access.line.me",
    "scopes": ["openid", "profile", "email"],
    "button": {
      "label": "使用 LINE 繼續",
      "svg": "<svg viewBox=\"0 0 24 24\" xmlns=\"http://www.w3.org/2000/svg\"><path fill=\"#ffffff\" d=\"M12 3C6.5 3 2 6.6 2 11c0 3.9 3.5 7.2 8.3 7.9.3.1.7.2.8.5.1.3.1.7 0 1l-.1.8c0 .2-.2.9.8.5s5.4-3.2 7.4-5.5c1.4-1.5 2-3 2-4.7C22 6.6 17.5 3 12 3z\"/></svg>",
      "background": "#06C755",
      "foreground": "#ffffff"
    }
  },
  "settings": [
    {
      "key": "clientId",
      "label": {
        "en": "Channel ID",
        "zh-Hant": "頻道 ID"
      },
      "description": {
        "en": "LINE Login channel ID from the LINE Developers console.",
        "zh-Hant": "來自 LINE Developers 主控台的 LINE Login 頻道 ID。"
      },
      "type": "text",
      "default": ""
    },
    {
      "key": "clientSecret",
      "label": {
        "en": "Channel secret",
        "zh-Hant": "頻道密鑰"
      },
      "description": {
        "en": "LINE Login channel secret. Stored encrypted.",
        "zh-Hant": "LINE Login 頻道密鑰。加密儲存。"
      },
      "type": "text",
      "secret": true,
      "default": ""
    }
  ]
}
