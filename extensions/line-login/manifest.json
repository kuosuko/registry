{
  "kind": "declarative",
  "id": "line-login",
  "name": "LINE Login",
  "version": "1.0.0",
  "coreApi": "^1.16.0",
  "description": "Sign in with LINE (OIDC). The email scope requires LINE review; without it users get a placeholder address and can add a real one later.",
  "author": { "name": "kuosuko" },
  "license": "MIT",
  "category": "integration",
  "tags": ["auth", "login", "oidc", "line"],
  "deployment": "instant",
  "repository": "https://github.com/kuosuko/registry",
  "loginProvider": {
    "issuer": "https://access.line.me",
    "scopes": ["openid", "profile", "email"],
    "button": {
      "label": "使用 LINE 繼續",
      "svg": "<svg viewBox=\"0 0 24 24\" xmlns=\"http://www.w3.org/2000/svg\"><path fill=\"#ffffff\" d=\"M12 3C6.5 3 2 6.6 2 11c0 3.9 3.5 7.2 8.3 7.9.3.1.7.2.8.5.1.3.1.7 0 1l-.1.8c0 .2-.2.9.8.5s5.4-3.2 7.4-5.5c1.4-1.5 2-3 2-4.7C22 6.6 17.5 3 12 3z\"/></svg>",
      "background": "#06C755",
      "foreground": "#ffffff"
    }
  },
  "settings": [
    {
      "key": "clientId",
      "label": "Channel ID",
      "description": "LINE Login channel ID from the LINE Developers console.",
      "type": "text",
      "default": ""
    },
    {
      "key": "clientSecret",
      "label": "Channel secret",
      "description": "LINE Login channel secret. Stored encrypted.",
      "type": "text",
      "secret": true,
      "default": ""
    }
  ]
}
