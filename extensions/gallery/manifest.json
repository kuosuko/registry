{
  "kind": "declarative",
  "id": "gallery",
  "name": {
    "en": "Gallery",
    "zh-Hant": "相片集"
  },
  "version": "1.2.4",
  "coreApi": "^1.17.0",
  "description": {
    "en": "Photo gallery with street/studio tagging, admin collection view, and public list/detail pages.",
    "zh-Hant": "帶有街景/棚拍標籤、管理者集合檢視和公開列表/詳細內容頁面的相片集。"
  },
  "contentTypes": [
    {
      "name": "item",
      "label": {
        "en": "Gallery item",
        "zh-Hant": "相片"
      },
      "slugField": "title",
      "fields": [
        {
          "key": "title",
          "type": "text",
          "required": true,
          "label": {
            "en": "Title",
            "zh-Hant": "標題"
          }
        },
        {
          "key": "image",
          "type": "media",
          "label": {
            "en": "Image",
            "zh-Hant": "相片"
          }
        },
        {
          "key": "body",
          "type": "richtext",
          "label": {
            "en": "Body",
            "zh-Hant": "內文"
          }
        },
        {
          "key": "shotAt",
          "type": "date",
          "label": {
            "en": "Shot at",
            "zh-Hant": "拍攝時間"
          }
        },
        {
          "key": "tag",
          "type": "select",
          "label": {
            "en": "Tag",
            "zh-Hant": "標籤"
          },
          "options": [
            "street",
            "studio"
          ]
        }
      ]
    }
  ],
  "settings": [
    {
      "key": "perPage",
      "label": {
        "en": "Items per page",
        "zh-Hant": "每頁相片數"
      },
      "description": {
        "en": "Number of gallery items shown per page on the public list view.",
        "zh-Hant": "公開列表檢視中每頁顯示的相片數量。"
      },
      "type": "number",
      "default": 12
    }
  ],
  "adminPages": [
    {
      "slug": "",
      "title": {
        "en": "Gallery",
        "zh-Hant": "相片集"
      },
      "view": "collection",
      "contentType": "item",
      "layout": "grid"
    }
  ],
  "publicRoutes": [
    {
      "pattern": "/gallery",
      "view": "list",
      "contentType": "item",
      "layout": "grid"
    },
    {
      "pattern": "/gallery/:slug",
      "view": "detail",
      "contentType": "item"
    }
  ],
  "author": {
    "name": "kuosuko",
    "url": "https://suko.tw"
  },
  "repository": "https://github.com/kuosuko/registry",
  "license": "MIT",
  "category": "media",
  "tags": [
    "gallery",
    "photos",
    "portfolio"
  ],
  "deployment": "instant",
  "capabilities": [
    "contents",
    "media",
    "settings",
    "admin-pages",
    "public-routes"
  ],
  "iconUrl": "icon.png"
}
